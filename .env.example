# Application
APP_ENV=development
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/us_address_proxy

# Redis
REDIS_URL=redis://localhost:6379/0

# Token
TOKEN_EXPIRE_SECONDS=3600

# External API
ADDRESS_API_URL=https://www.meiguodizhi.com/api/v1/dz
ADDRESS_API_REFERER=https://www.meiguodizhi.com/
ADDRESS_API_TIMEOUT=10.0
ADDRESS_API_MOCK_ON_FAILURE=true

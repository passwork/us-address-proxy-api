{
  "info": {
    "_postman_id": "us-address-proxy-api",
    "name": "US Address Proxy API",
    "description": "US Address Proxy Service — Postman 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Step 1: 登录获取 Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account\": \"test\",\n  \"pwd\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/v1/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response code is 200', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.code).to.eql(200);",
              "});",
              "pm.test('Token exists', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.token).to.exist;",
              "    pm.environment.set('token', jsonData.data.token);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 2: 携带 Token 获取地址",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:8000/api/v1/address/generate",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "address", "generate"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Address field exists', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.address).to.exist;",
              "    pm.expect(jsonData.data.address.Address).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 3: 无 Token 访问地址（应 401）",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/v1/address/generate",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "address", "generate"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 401', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "pm.test('Response code is 401', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.code).to.eql(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "错误密码登录（应 400）",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account\": \"test\",\n  \"pwd\": \"wrong_password\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/v1/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Response msg contains error', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.code).to.eql(400);",
              "    pm.expect(jsonData.msg).to.contain('账号或密码错误');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "缺少密码（应 422）",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account\": \"test\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/v1/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 422', function () {",
              "    pm.response.to.have.status(422);",
              "});",
              "pm.test('Response code is 422', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.code).to.eql(422);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "白名单 /docs（免鉴权）",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/docs",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["docs"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
